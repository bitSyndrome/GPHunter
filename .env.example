# Ghost Project Hunter — server/dev configuration
# Copy to .env and adjust. (.env is gitignored; dev.sh auto-loads it.)

# ── Network ──────────────────────────────────────────────────────────────────
# API server bind host. 0.0.0.0 = reachable from other PCs on the LAN.
GPH_HOST=0.0.0.0
# API server port.
PORT=8787
# Web (Vite) dev server port. 5173 is the vite default and often taken.
WEB_PORT=5273

# ── Auth ─────────────────────────────────────────────────────────────────────
# Seed API token created on first boot. CHANGE THIS for any shared/LAN server.
# Devices authenticate with: ghost-hunter login http://<host>:8787 <token>
GPH_SEED_TOKEN=change-me

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite file path. Put on a persistent volume when deployed.
GPH_DB_PATH=./data/gph.sqlite

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allowed origin for browser requests. "*" is fine for token-gated LAN use;
# set an explicit origin (e.g. http://192.168.0.142:5273) to lock it down.
GPH_CORS_ORIGIN=*

# ── Rate limiting (/events, in-memory token bucket) ──────────────────────────
# Burst capacity per device/user, and sustained refill rate (tokens/second).
# Defaults allow a 60-event burst then 1 event/sec — generous for hooks.
GPH_RATE_CAPACITY=60
GPH_RATE_REFILL=1
