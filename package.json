{
  "name": "ghost-project-hunter",
  "version": "0.1.0",
  "private": true,
  "description": "Track AI CLI 'ghost projects' on a game leaderboard",
  "workspaces": [
    "shared",
    "server",
    "cli",
    "web"
  ],
  "scripts": {
    "build:shared": "npm run build -w shared",
    "build": "npm run build:shared && npm run build -w server && npm run build -w web",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "test": "npm run test -w shared",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
